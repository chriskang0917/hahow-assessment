{
  "name": "react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "build": "tsc -b && vite build",
    "lint": "biome check src && eslint src",
    "lint:fix": "biome check --write src && eslint --fix src",
    "type-check": "tsc -b",
    "format": "biome check --write src && prettier --write src/**/*.{ts,tsx}",
    "preview": "vite preview",
    "analyze": "npx vite-bundle-visualizer"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@tailwindcss/vite": "^4.1.10",
    "@tanstack/react-query": "5.80.7",
    "@tanstack/react-router": "^1.121.16",
    "@tanstack/react-router-devtools": "^1.121.16",
    "axios": "^1.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.518.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.0.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.10",
    "zod": "^3.25.67",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@tanstack/eslint-plugin-query": "^5.78.0",
    "@tanstack/router-plugin": "^1.121.16",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "eslint": "^9.25.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "msw": "^2.12.10",
    "path": "^0.12.7",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "tw-animate-css": "^1.3.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977",
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched",
      "prettier --write"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}